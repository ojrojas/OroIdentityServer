@using OroIdentity.Web.Client.Interfaces
@inject OroIdentity.Web.Client.Interfaces.IToastService ToastService
@implements IDisposable

<div style="position: fixed; top: 1rem; right: 1rem; z-index: 2000;">
    @foreach (var t in messages)
    {
        <div style="margin-bottom:8px; min-width:240px;">
            <FluentCard>
                <div style="padding:8px; display:flex; flex-direction:column;">
                    <div>@t.Message</div>
                </div>
            </FluentCard>
        </div>
    }
</div>

@code {
    private List<ToastMessage> messages = new();

    protected override void OnInitialized()
    {
        ToastService.OnShow += HandleToastShow;
    }

    private void HandleToastShow(ToastMessage msg)
    {
        messages.Add(msg);
        StateHasChanged();
        _ = DismissAfterAsync(msg);
    }

    private async Task DismissAfterAsync(ToastMessage msg)
    {
        await Task.Delay(msg.DurationMs);
        messages.RemoveAll(m => m.Id == msg.Id);
        StateHasChanged();
    }

    public void Dispose()
    {
        ToastService.OnShow -= HandleToastShow;
    }
}
