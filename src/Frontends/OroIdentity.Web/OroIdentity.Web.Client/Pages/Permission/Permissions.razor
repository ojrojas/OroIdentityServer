@page "/permissions"
@using OroIdentity.Web.Client.Interfaces
@using OroIdentity.Web.Client.Models

@attribute [Authorize]

@inject NavigationManager NavigationManager
@inject IPermissionsService Service

<PageTitle>Permissions</PageTitle>

<HeaderPagesComponent TitlePage="Permissions" Description="Manage your permissions">
    <FluentButton Appearance="Appearance.Accent" OnClick="RedirectToCreatePage">Create</FluentButton>
</HeaderPagesComponent>

<FluentDivider Style="width: 100%;height:30px;" Orientation=Orientation.Horizontal Role="DividerRole.Separator">
</FluentDivider>
<FluentDataGrid Items="permissions" Style="width:100%;">
    <TemplateColumn Title="Action">
        <FluentButton OnClick="(() => RedirectEdit(context.PermissionId.Value))" Appearance="Appearance.Accent">Edit
        </FluentButton>
    </TemplateColumn >
    <TemplateColumn Title="Name">
        @context.Name
    </TemplateColumn>
    <TemplateColumn Title="Display">
        @context.DisplayName
    </TemplateColumn>
    <TemplateColumn Title="Resource">
        @context.Resource
    </TemplateColumn>
    <TemplateColumn Title="System">
        @context.IsSystem
    </TemplateColumn>
</FluentDataGrid>

@code {
    [PersistentState]
    public IQueryable<PermissionViewModel> permissions { get; set; }

     GridSort<PermissionViewModel> sortByName = GridSort<PermissionViewModel>
        .ByAscending(p => p.Name)
        .ThenAscending(p => p.DisplayName);

    protected override async Task OnInitializedAsync()
    {
        await LoadPermissions();
    }

    private async Task LoadPermissions()
    {
        CancellationTokenSource cts = new CancellationTokenSource(TimeSpan.FromMinutes(2));
        var list = await Service.GetAllPermissionsAsync(cts.Token);
        permissions = list.Data.AsQueryable();
    }

    private void RedirectToCreatePage()
    {
        NavigationManager.NavigateTo("/create-permission");
    }

    private void RedirectEdit(Guid id)
    {
        NavigationManager.NavigateTo($"/permissions/{id}");
    }
}