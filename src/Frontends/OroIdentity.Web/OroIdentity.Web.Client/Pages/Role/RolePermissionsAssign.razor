@using OroIdentity.Web.Client.Interfaces
@using OroIdentity.Web.Client.Models
@inject IPermissionsService PermissionsService
@inject IRoleClaimsService RoleClaimsService
@inject OroIdentity.Web.Client.Interfaces.IToastService ToastService

@code {
    [Parameter]
    public Guid RoleId { get; set; }

    private List<PermissionViewModel> permissions = new();
    private HashSet<Guid> selected = new();
    private bool isLoading = true;
    private bool isAssigning = false;
    private bool selectAll = false;

    protected override async Task OnParametersSetAsync()
    {
        await LoadPermissions();
    }

    private async Task LoadPermissions()
    {
        isLoading = true;
        try
        {
            var resp = await PermissionsService.GetAllPermissionsAsync(CancellationToken.None);
            permissions = resp.Data?.ToList() ?? new List<PermissionViewModel>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleSelection(Guid id, ChangeEventArgs _) => ToggleSelection(id);
    private void ToggleSelection(Guid id)
    {
        if (!selected.Add(id)) selected.Remove(id);
    }

    private void ToggleSelectAll()
    {
        selectAll = !selectAll;
        selected.Clear();
        if (selectAll)
        {
            foreach (var p in permissions) selected.Add(p.PermissionId.Value);
        }
    }

    private async Task AssignSelected()
    {
        if (RoleId == Guid.Empty)
        {
            ToastService.ShowError("Role not selected");
            return;
        }
        if (!selected.Any())
        {
            ToastService.ShowError("Select at least one permission to assign");
            return;
        }

        isAssigning = true;
        try
        {
            await RoleClaimsService.AssociatePermissionsToRoleAsync(RoleId, selected.ToList(), CancellationToken.None);
            await LoadPermissions();
            ToastService.ShowSuccess($"Assigned {selected.Count} permission(s) to role");
        }
        catch (Exception ex)
        {
            ToastService.ShowError($"Error assigning permissions: {ex.Message}");
        }
        finally
        {
            isAssigning = false;
        }
    }
}

<FluentCard>
    <FluentStack Orientation="Orientation.Vertical" Gap="1rem">
        <FluentLabel Typo="Typography.H6">Bulk assign permissions</FluentLabel>

        <FluentStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
            <label style="display:flex;align-items:center;gap:8px;">
                <input type="checkbox" checked="@selectAll" @onchange="@(_ => ToggleSelectAll())" />
                <span>Select all</span>
            </label>
            <FluentButton Appearance="Appearance.Accent" OnClick="AssignSelected" Disabled="@isAssigning">
                @(isAssigning ? "Assigning..." : "Assign Selected")
            </FluentButton>
        </FluentStack>

        @if (isLoading)
        {
            <div>Loading permissions...</div>
        }
        else
        {
            <div style="max-height:320px;overflow:auto;">
                @foreach (var p in permissions)
                {
                    <div style="display:flex;align-items:center;gap:8px;padding:4px;">
                        <input type="checkbox" checked="@selected.Contains(p.PermissionId.Value)" @onchange="@(_ => ToggleSelection(p.PermissionId.Value))" />
                        <div>@p.Name - <small>@p.DisplayName</small></div>
                    </div>
                }
            </div>
        }
    </FluentStack>
</FluentCard>