@using OroIdentity.Web.Client.Models
@using OroIdentity.Web.Client.Interfaces
@inject NavigationManager NavigationManager
@inject IRoleClaimsService Service
@inject IJSRuntime JSRuntime

@code {
    [Parameter]
    public Guid RoleId { get; set; }

    private List<RoleClaimViewModel> Claims = new List<RoleClaimViewModel>();

    private string newClaimType = string.Empty;
    private string newClaimValue = string.Empty;
    private bool isAdding = false;
    private bool isUpdating = false;
    private string? operationMessage;

    protected override async Task OnParametersSetAsync()
    {
        await LoadClaims();
    }

    private async Task LoadClaims()
    {
        if (RoleId == Guid.Empty) return;
        var response = await Service.GetRoleClaimsByRoleIdAsync(RoleId, CancellationToken.None);
        Claims = response.Data?.ToList() ?? new List<RoleClaimViewModel>();
    }

    private async Task AddClaim()
    {
        if (RoleId == Guid.Empty) return;
        if (string.IsNullOrWhiteSpace(newClaimType) || string.IsNullOrWhiteSpace(newClaimValue))
        {
            await JSRuntime.InvokeVoidAsync("alert", "Claim type and value are required.");
            return;
        }

        isAdding = true;
        operationMessage = null;
        try
        {
            await Service.AssociateClaimToRoleAsync(RoleId, newClaimType.Trim(), newClaimValue.Trim(), CancellationToken.None);
            newClaimType = string.Empty;
            newClaimValue = string.Empty;
            await LoadClaims();
            operationMessage = "Claim added successfully.";
        }
        catch (Exception ex)
        {
            operationMessage = $"Error adding claim: {ex.Message}";
        }
        finally
        {
            isAdding = false;
        }
    }

    private void EditClaim(RoleClaimViewModel claim)
    {
        NavigationManager.NavigateTo($"/roles/edit-claim/{claim.Id.Value}");
    }

    private async Task DeleteClaim(RoleClaimViewModel claim)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Delete claim?");
        if (!confirmed) return;
        await Service.DeleteRoleClaimAsync(claim.Id.Value, CancellationToken.None);
        await LoadClaims();
    }

    private async Task ToggleActive(RoleClaimViewModel claim)
    {
        if (claim == null) return;
        isUpdating = true;
        var original = claim.IsActive;
        claim.IsActive = !original;
        try
        {
            await Service.UpdateRoleClaimAsync(claim, CancellationToken.None);
            await LoadClaims();
        }
        catch
        {
            claim.IsActive = original;
        }
        finally
        {
            isUpdating = false;
        }
    }
}

<FluentCard>
    <FluentStack Orientation="Orientation.Horizontal" Gap="1rem" AlignItems="AlignItems.Center">
        <FluentTextField Label="Claim Type" @bind-Value="newClaimType" />
        <FluentTextField Label="Claim Value" @bind-Value="newClaimValue" />
        <FluentButton Appearance="Appearance.Accent" OnClick="@(async () => await AddClaim())" Disabled="@isAdding">
            @if (isAdding) { <text>Adding...</text> } else { <text>Add</text> }
        </FluentButton>
        @if (!string.IsNullOrEmpty(operationMessage))
        {
            <div>@operationMessage</div>
        }
    </FluentStack>
</FluentCard>

<FluentDivider Style="width: 100%;height:20px;" Orientation=Orientation.Horizontal Role="DividerRole.Separator"></FluentDivider>

<table>
    <thead>
        <tr>
            <th>Type</th>
            <th>Value</th>
            <th>Active</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var claim in Claims)
        {
            <tr>
                <td>@claim.ClaimType</td>
                <td>@claim.ClaimValue</td>
                <td>@(claim.IsActive ? "Yes" : "No")</td>
                <td>
                    <FluentButton Appearance="Appearance.Accent" OnClick="@(() => EditClaim(claim))">Edit</FluentButton>
                    <FluentButton Appearance="Appearance.Accent" OnClick="@(async () => await ToggleActive(claim))" Disabled="@isUpdating">@(claim.IsActive ? "Disable" : "Enable")</FluentButton>
                    <FluentButton Appearance="Appearance.Stealth" OnClick="@(async () => await DeleteClaim(claim))">Delete</FluentButton>
                </td>
            </tr>
        }
    </tbody>
</table>