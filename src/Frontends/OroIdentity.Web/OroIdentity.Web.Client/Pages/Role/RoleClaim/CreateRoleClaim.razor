@page "/roles/{RoleId:guid}/create-claim"

@attribute [Authorize]

@using OroIdentity.Web.Client.Interfaces
@using OroIdentity.Web.Client.Models

@inject NavigationManager NavigationManager
@inject IRoleClaimsService Service

<PageTitle>Create Role Claim</PageTitle>

<HeaderPagesComponent TitlePage="Roles" Description="Create a claim for role">
    <FluentButton Appearance="Appearance.Accent" OnClick="RedirectToRoles">Back</FluentButton>
</HeaderPagesComponent>

<FluentDivider Style="width: 100%;height:20px;" Orientation=Orientation.Horizontal Role="DividerRole.Separator">
</FluentDivider>

<FluentCard>
    <FluentStack Orientation="Orientation.Vertical" Gap="1rem">
        <FluentTextField Label="Claim Type" @bind-Value="ClaimType" />
        <FluentTextField Label="Claim Value" @bind-Value="ClaimValue" />
        <FluentButton Appearance="Appearance.Accent" OnClick="CreateClaim">Create</FluentButton>
    </FluentStack>
</FluentCard>

@code {
    [Parameter]
    public Guid RoleId { get; set; }
    private string ClaimType { get; set; } = string.Empty;
    private string ClaimValue { get; set; } = string.Empty;

    private RoleClaimViewModel? claim { get; set; }

    protected override void OnInitialized()
    {
        claim ??= new RoleClaimViewModel();
        base.OnInitialized();
    }

    private void RedirectToRoles()
    {
        NavigationManager.NavigateTo($"/roles/{RoleId}");
    }

    private async Task CreateClaim()
    {
        await Service.AssociateClaimToRoleAsync(
            RoleId,
            ClaimType,
            ClaimValue,
            CancellationToken.None);
        NavigationManager.NavigateTo($"/roles/{RoleId}");
    }
}