@page "/tenants/{Id:guid}"
@using OroIdentity.Web.Client.Interfaces
@using OroIdentity.Web.Client.Models
@using System.ComponentModel.DataAnnotations

@attribute [Authorize]

@inject NavigationManager NavigationManager
@inject ITenantsService Service
@inject IToastService Toast

<PageTitle>Edit Tenant</PageTitle>

<HeaderPagesComponent TitlePage="Edit Tenant" Description="Edit tenant details">
</HeaderPagesComponent>

<FluentDivider Style="width: 100%;height:20px;" Orientation=Orientation.Horizontal Role="DividerRole.Separator">
</FluentDivider>

@if (tenant == null)
{
    <p>Loading...</p>
}
else
{
    <FluentEditForm Model="model" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />
        <FluentTextField @bind-Value="model.Name" Placeholder="Tenant name" Label="Name" Required="true"></FluentTextField>
        <ValidationMessage For="@(() => model.Name)" />
        <FluentCheckbox @bind-Checked="model.IsActive">Active</FluentCheckbox>
        <FluentButton Type="@(Microsoft.FluentUI.AspNetCore.Components.ButtonType.Submit)" Appearance="Appearance.Accent">Save</FluentButton>
    </FluentEditForm>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private TenantViewModel? tenant;
    private TenantFormModel model = new();

    private class TenantFormModel
    {
        [Required(ErrorMessage = "Name is required")]
        [StringLength(100, ErrorMessage = "Name must be at most 100 characters")]
        public string Name { get; set; } = string.Empty;
        public bool IsActive { get; set; } = true;
    }

    protected override async Task OnInitializedAsync()
    {
        tenant = await Service.GetTenantByIdAsync(Id, CancellationToken.None);
        if (tenant == null)
        {
            Toast.ShowError("Tenant not found");
            NavigationManager.NavigateTo("/tenants");
            return;
        }

        model.Name = tenant.Name.Value;
        model.IsActive = tenant.IsActive;
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            var request = new UpdateTenantRequest(model.Name, model.IsActive);
            await Service.UpdateTenantAsync(Id, request, CancellationToken.None);
            Toast.ShowSuccess("Tenant updated");
            NavigationManager.NavigateTo("/tenants");
        }
        catch (Exception ex)
        {
            Toast.ShowError(ex.Message);
        }
    }
}
