@page "/sessions"
@attribute [Authorize]

@using OroIdentity.Web.Client.Models
@using OroIdentity.Web.Client.Interfaces

@inject ISessionsService Service
@inject OroIdentity.Web.Client.Interfaces.IToastService ToastService
@inject NavigationManager NavigationManager

<PageTitle>Active Sessions</PageTitle>

<HeaderPagesComponent TitlePage="Active Sessions" Description="List of active user sessions">
</HeaderPagesComponent>

<FluentDivider Style="width: 100%;height:20px;" Orientation=Orientation.Horizontal Role="DividerRole.Separator">
</FluentDivider>

@if (sessions == null)
{
    <p>Loading...</p>
}
else
{
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
        <div>
            <FluentTextField Placeholder="Filter by user..." @bind-Value="filterUser" />
        </div>
        <div>
            <FluentButton OnClick="PrevPage" Disabled="@(_currentPage == 1)">Previous</FluentButton>
            <FluentButton OnClick="NextPage" Disabled="@(_currentPage >= TotalPages)">Next</FluentButton>
            <span style="margin-left:8px">Page @_currentPage of @TotalPages</span>
        </div>
    </div>

    <FluentDataGrid Items="displayedSessions" Style="width:100%;">
        <TemplateColumn Title="Action">
            @if (pendingTerminateSessionId.HasValue && context.Id.Value == pendingTerminateSessionId.Value)
            {
                <FluentButton OnClick="async () => await ConfirmTerminateNow(context.Id.Value)" Appearance="Appearance.Accent">Confirm</FluentButton>
                <FluentButton OnClick="CancelConfirm">Cancel</FluentButton>
            }
            else
            {
                <FluentButton OnClick="(() => ShowConfirmTerminate(context.Id.Value))" Appearance="Appearance.Accent">Terminate</FluentButton>
            }
        </TemplateColumn>
        <TemplateColumn Title="User">
            @context.UserDisplayName
        </TemplateColumn>
        <TemplateColumn Title="IP">
            @context.IpAddress
        </TemplateColumn>
        <TemplateColumn Title="Country">
            @context.Country
        </TemplateColumn>
        <TemplateColumn Title="Started">
            @context.StartedAtUtc.ToLocalTime().ToString("g")
        </TemplateColumn>
        <TemplateColumn Title="Duration">
            @GetDuration(context)
        </TemplateColumn>
    </FluentDataGrid>
}

@code {
    private IQueryable<SessionViewModel>? sessions;
    private IQueryable<SessionViewModel> displayedSessions => GetDisplayedSessions().AsQueryable();
    private string filterUser = string.Empty;
    private int _currentPage = 1;
    private int _pageSize = 10;

    private int TotalPages => sessions == null || !sessions.Any() ? 1 : (int)Math.Ceiling((double)sessions.Count() / _pageSize);

    protected override async Task OnInitializedAsync()
    {
        await LoadSessions();
    }

    private async Task LoadSessions()
    {
        var result = await Service.GetAllSessionsAsync(CancellationToken.None);
        sessions = result.Data.AsQueryable();
        _currentPage = 1;
        StateHasChanged();
    }

    private IEnumerable<SessionViewModel> GetDisplayedSessions()
    {
        if (sessions == null) return Enumerable.Empty<SessionViewModel>();
        var query = sessions.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(filterUser))
            query = query.Where(s => !string.IsNullOrEmpty(s.UserDisplayName) && s.UserDisplayName.Contains(filterUser, StringComparison.OrdinalIgnoreCase));
        return query.Skip((_currentPage - 1) * _pageSize).Take(_pageSize);
    }

    private string GetDuration(SessionViewModel s)
    {
        var end = s.EndedAtUtc ?? DateTime.UtcNow;
        var span = end - s.StartedAtUtc;
        if (span.TotalSeconds < 60) return $"{(int)span.TotalSeconds}s";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}h";
        return $"{(int)span.TotalDays}d";
    }

    private Guid? pendingTerminateSessionId;

    private void ShowConfirmTerminate(Guid sessionId)
    {
        pendingTerminateSessionId = sessionId;
    }

    private void CancelConfirm()
    {
        pendingTerminateSessionId = null;
    }

    private async Task ConfirmTerminateNow(Guid sessionId)
    {
        await Service.TerminateSessionAsync(sessionId, CancellationToken.None);
        pendingTerminateSessionId = null;
        ToastService.ShowSuccess("Session terminated.");
        await LoadSessions();
    }

    private void PrevPage()
    {
        if (_currentPage > 1) _currentPage--;
    }

    private void NextPage()
    {
        if (_currentPage < TotalPages) _currentPage++;
    }
}
