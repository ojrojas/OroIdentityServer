@page "/Account/ChangePassword"
@layout LoginLayout
@attribute [Authorize]
@using Microsoft.FluentUI.AspNetCore.Components
@inject IStringLocalizer<SharedResources> L

<div class="login-page">
    <LanguagePicker />

    <FluentCard class="login-card">
        <div class="login-card-header">
            <span class="login-icon">
                <FluentIcon Value="@(new Icons.Regular.Size24.LockClosed())" />
            </span>
            <h1>@L["ChangePasswordTitle"]</h1>
            <p class="login-subtitle">@L["ChangePasswordSubtitle"]</p>
        </div>

        @if (Error == "mismatch")
        {
            <div class="login-error">
                <FluentIcon Value="@(new Icons.Regular.Size20.DismissCircle())" Color="@Color.Error" />
                <span>@L["PasswordMismatch"]</span>
            </div>
        }

        <form action="/auth/change-password" method="post" class="login-form">
            <FluentTextField
                Type="@TextFieldType.Password"
                Name="NewPassword"
                Placeholder="@L["NewPasswordPlaceholder"]"
                Required="true"
                Autofocus="true"
                Class="login-field" />

            <FluentTextField
                Type="@TextFieldType.Password"
                Name="ConfirmPassword"
                Placeholder="@L["ConfirmNewPasswordPlaceholder"]"
                Required="true"
                Class="login-field" />

            <FluentButton Type="@ButtonType.Submit" Appearance="@Appearance.Accent" FullWidth="true" Class="login-btn">
                @L["ChangePasswordButton"]
            </FluentButton>
        </form>
    </FluentCard>
</div>

@code {
    [SupplyParameterFromQuery] public string? Error { get; set; }
}
