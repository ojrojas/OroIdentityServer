@page "/Account/Login"
@layout LoginLayout
@attribute [AllowAnonymous]
@using Microsoft.FluentUI.AspNetCore.Components
@inject IStringLocalizer<SharedResources> L

<div class="login-page">
    <LanguagePicker />

    <FluentCard class="login-card">
        <div class="login-brand">
            <FluentIcon Value="@(new Icons.Regular.Size16.Shield())" />
            <span>@L["AdminPanel"]</span>
        </div>

        <div class="login-card-header">
            <span class="login-icon">
                <FluentIcon Value="@(new Icons.Regular.Size24.LockClosed())" />
            </span>
            <h1>@L["SignInTitle"]</h1>
            <p class="login-subtitle">@L["SignInSubtitle"]</p>
        </div>

        @if (!string.IsNullOrEmpty(Error))
        {
            <div class="login-error">
                <FluentIcon Value="@(new Icons.Regular.Size20.DismissCircle())" Color="@Color.Error" />
                <span>@L["InvalidCredentials"]</span>
            </div>
        }

        <form action="/auth/login" method="post" class="login-form">
            <input type="hidden" name="ReturnUrl" value="@ReturnUrl" />

            <FluentTextField
                Name="LoginIdentifier"
                Placeholder="@L["LoginIdentifierPlaceholder"]"
                Required="true"
                Autofocus="true"
                Class="login-field" />

            <FluentTextField
                Type="@TextFieldType.Password"
                Name="Password"
                Placeholder="&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;"
                Required="true"
                Class="login-field" />

            <FluentButton Type="@ButtonType.Submit" Appearance="@Appearance.Accent" FullWidth="true" Class="login-btn">
                @L["SignInButton"]
            </FluentButton>
        </form>

        <div class="login-footer">OroIdentityServer</div>
    </FluentCard>
</div>

@code {
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery] public string? Error { get; set; }
}
