@page "/"
@attribute [Authorize]
@inject IAdminUserService UserService
@inject IAdminRoleService RoleService
@inject IAdminScopeService ScopeService
@inject IAdminApplicationService ApplicationService
@inject IAdminUserSessionService UserSessionService
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["DashboardTitle"]</PageTitle>

<FluentLabel Typo="Typography.PageTitle">@L["DashboardTitle"]</FluentLabel>

<FluentGrid Style="margin-top: 1rem;">
    <FluentGridItem xs="12" sm="6" md="3">
        <StatCard Title="@L["StatUsers"]" Value="@userCount" Icon="@(new Icons.Regular.Size24.PeopleCommunity())" />
    </FluentGridItem>
    <FluentGridItem xs="12" sm="6" md="3">
        <StatCard Title="@L["StatConnectedUsers"]" Value="@connectedUserCount" Icon="@(new Icons.Regular.Size24.PlugConnected())" />
    </FluentGridItem>
    <FluentGridItem xs="12" sm="6" md="3">
        <StatCard Title="@L["StatRoles"]" Value="@roleCount" Icon="@(new Icons.Regular.Size24.Shield())" />
    </FluentGridItem>
    <FluentGridItem xs="12" sm="6" md="3">
        <StatCard Title="@L["StatApplications"]" Value="@applicationCount" Icon="@(new Icons.Regular.Size24.Apps())" />
    </FluentGridItem>
    <FluentGridItem xs="12" sm="6" md="3">
        <StatCard Title="@L["StatScopes"]" Value="@scopeCount" Icon="@(new Icons.Regular.Size24.Key())" />
    </FluentGridItem>
</FluentGrid>

@if (activeSessions is not null && activeSessions.Count > 0)
{
    <FluentStack Orientation="Orientation.Vertical" Style="margin-top: 2rem;">
        <FluentLabel Typo="Typography.Subject">@L["ConnectedUsersDetail"] (@connectedUserCount)</FluentLabel>
        <FluentDataGrid Items="@activeSessions.AsQueryable()" GridTemplateColumns="1.5fr 1fr 1.5fr 1.5fr 0.5fr">
            <TemplateColumn Title="@L["ColUsername"]">
                @(context.UserId?.ToString() ?? "-")
            </TemplateColumn>
            <TemplateColumn Title="@L["ColDevice"]">
                @(context.Device ?? "-")
            </TemplateColumn>
            <TemplateColumn Title="@L["ColIp"]">
                @(context.IpAddress ?? "-")
            </TemplateColumn>
            <TemplateColumn Title="@L["ColLastActivity"]">
                @FormatLastActivity(context.LastActivityAt)
            </TemplateColumn>
            <TemplateColumn Title="@L["ColExpires"]">
                @context.ExpiresAt.ToString("g")
            </TemplateColumn>
        </FluentDataGrid>
    </FluentStack>
}

@code {
    private int? userCount;
    private int? connectedUserCount;
    private int? roleCount;
    private int? scopeCount;
    private int? applicationCount;
    private List<UserSessionModel>? activeSessions;

    private static string FormatLastActivity(DateTime? dt)
        => dt.HasValue ? dt.Value.ToString("g") : "-";

    protected override async Task OnInitializedAsync()
    {
        var users = await UserService.GetUsersAsync();
        userCount = users?.Data?.Count() ?? 0;

        connectedUserCount = await UserSessionService.GetActiveSessionsCountAsync();

        var allSessions = await UserSessionService.GetActiveSessionsAsync();
        activeSessions = allSessions?.ToList() ?? [];

        var roles = await RoleService.GetRolesAsync();
        roleCount = roles?.Data?.Count() ?? 0;

        var applications = await ApplicationService.GetApplicationsAsync();
        applicationCount = applications?.Count() ?? 0;

        var scopes = await ScopeService.GetScopesAsync();
        scopeCount = scopes?.Count() ?? 0;
    }
}
