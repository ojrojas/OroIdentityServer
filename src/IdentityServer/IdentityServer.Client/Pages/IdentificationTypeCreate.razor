@page "/identification-types/create"
@attribute [Authorize]
@inject IAdminIdentificationTypeService IdentificationTypeService
@inject IToastService ToastService
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["NewIdentificationTypeTitle"]</PageTitle>

<FluentLabel Typo="Typography.PageTitle">@L["NewIdentificationTypeTitle"]</FluentLabel>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="16" Style="max-width: 480px; margin-top: 1rem;">
    <FluentTextField @bind-Value="name" Label="@L["Name"]" Required="true" Style="width:100%" />

    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
        <FluentButton Appearance="Appearance.Accent" Disabled="@(string.IsNullOrWhiteSpace(name) || saving)" OnClick="SubmitAsync">@L["Create"]</FluentButton>
        <FluentButton Appearance="Appearance.Neutral" OnClick="@(() => Nav.NavigateTo("/identification-types"))">@L["Cancel"]</FluentButton>
    </FluentStack>
</FluentStack>

@code {
    private string name = string.Empty;
    private bool saving;

    private async Task SubmitAsync()
    {
        saving = true;
        var response = await IdentificationTypeService.CreateIdentificationTypeAsync(new CreateIdentificationTypeRequest(name));
        saving = false;

        if (response.IsSuccessStatusCode)
        {
            ToastService.ShowSuccess(L["IdentificationTypeCreatedToast"]);
            Nav.NavigateTo("/identification-types");
        }
        else
        {
            ToastService.ShowError(L["IdentificationTypeCreateFailedToast", (int)response.StatusCode]);
        }
    }
}
