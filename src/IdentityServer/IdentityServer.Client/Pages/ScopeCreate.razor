@page "/scopes/create"
@attribute [Authorize]
@inject IAdminScopeService ScopeService
@inject IToastService ToastService
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["NewScopeTitle"]</PageTitle>

<FluentLabel Typo="Typography.PageTitle">@L["NewScopeTitle"]</FluentLabel>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="12" Style="max-width: 480px; margin-top: 1rem;">
    <FluentTextField @bind-Value="name" Label="@L["ScopeName"]" Required="true" Style="width:100%" />
    <FluentTextField @bind-Value="resources" Label="@L["Resources"]" Style="width:100%" />

    <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
        <FluentButton Appearance="Appearance.Accent" Disabled="@(string.IsNullOrWhiteSpace(name) || saving)" OnClick="SubmitAsync">@L["Create"]</FluentButton>
        <FluentButton Appearance="Appearance.Neutral" OnClick="@(() => Nav.NavigateTo("/scopes"))">@L["Cancel"]</FluentButton>
    </FluentStack>
</FluentStack>

@code {
    private string name = string.Empty;
    private string resources = string.Empty;
    private bool saving;

    private async Task SubmitAsync()
    {
        saving = true;
        var resourceList = resources.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        var response = await ScopeService.CreateScopeAsync(new CreateOpenIddictScopeRequest(name, resourceList));
        saving = false;

        if (response.IsSuccessStatusCode)
        {
            ToastService.ShowSuccess(L["ScopeCreatedToast"]);
            Nav.NavigateTo("/scopes");
        }
        else
        {
            ToastService.ShowError(L["ScopeCreateFailedToast", (int)response.StatusCode]);
        }
    }
}
