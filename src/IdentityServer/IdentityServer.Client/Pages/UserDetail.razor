@page "/users/{Id:guid}"
@attribute [Authorize]
@inject IAdminUserService UserService
@inject IAdminIdentificationTypeService IdentificationTypeService
@inject IAdminTenantService TenantService
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject IToastService ToastService
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["UserDetailTitle"]</PageTitle>

@if (item is null || identificationTypes is null || tenants is null)
{
    <FluentProgressRing />
}
else
{
    <FluentLabel Typo="Typography.PageTitle">@L["UserDetailTitle"]</FluentLabel>

    <FluentStack Orientation="Orientation.Vertical" VerticalGap="12" Style="max-width: 560px; margin-top: 1rem;">
        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="12">
            <FluentTextField @bind-Value="name" Label="@L["Name"]" Required="true" Style="flex:1" />
            <FluentTextField @bind-Value="middleName" Label="@L["MiddleName"]" Style="flex:1" />
            <FluentTextField @bind-Value="lastName" Label="@L["LastName"]" Required="true" Style="flex:1" />
        </FluentStack>
        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="12">
            <FluentTextField @bind-Value="userName" Label="@L["Username"]" Required="true" Style="flex:1" />
            <FluentTextField @bind-Value="email" Label="@L["Email"]" Required="true" TextFieldType="TextFieldType.Email" Style="flex:1" />
        </FluentStack>
        <FluentTextField @bind-Value="password" Label="@L["Password"]" Placeholder="@L["NewPasswordRequiredPlaceholder"]" Required="true" TextFieldType="TextFieldType.Password" Style="width:100%" />
        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="12">
            <FluentTextField @bind-Value="identification" Label="@L["Identification"]" Required="true" Style="flex:1" />
            <FluentSelect Style="flex:1" TOption="IdentificationTypeModel" Items="identificationTypes" OptionText="@(x => x.Name)" OptionValue="@(x => x.Id.ToString())"
                          @bind-SelectedOption="selectedIdentificationType" Label="@L["IdentificationType"]" />
        </FluentStack>
        <FluentSelect Style="width:100%" TOption="TenantModel" Items="tenants" OptionText="@(x => x.Name)" OptionValue="@(x => x.Id.ToString())"
                      @bind-SelectedOption="selectedTenant" Label="@L["Tenant"]" />

        <FluentLabel>@L["RolesAssignedLabel", item.Roles.Count == 0 ? L["None"] : string.Join(", ", item.Roles.Select(r => r.RoleId))]</FluentLabel>

        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8">
            <FluentButton Appearance="Appearance.Accent" Disabled="@(saving || string.IsNullOrWhiteSpace(password))" OnClick="SaveAsync">@L["Save"]</FluentButton>
            <FluentButton Appearance="Appearance.Neutral" OnClick="@(() => Nav.NavigateTo("/users"))">@L["Back"]</FluentButton>
            <FluentSpacer />
            <FluentButton Appearance="Appearance.Stealth" IconStart="@(new Icons.Regular.Size20.Delete())" OnClick="DeleteAsync">@L["Delete"]</FluentButton>
        </FluentStack>
    </FluentStack>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private UserModel? item;
    private List<IdentificationTypeModel>? identificationTypes;
    private List<TenantModel>? tenants;
    private IdentificationTypeModel? selectedIdentificationType;
    private TenantModel? selectedTenant;

    private string name = string.Empty;
    private string middleName = string.Empty;
    private string lastName = string.Empty;
    private string userName = string.Empty;
    private string email = string.Empty;
    private string password = string.Empty;
    private string identification = string.Empty;
    private bool saving;

    protected override async Task OnInitializedAsync()
    {
        var identificationTypesResponse = await IdentificationTypeService.GetIdentificationTypesAsync();
        identificationTypes = identificationTypesResponse?.Data?.ToList() ?? [];

        var tenantsResponse = await TenantService.GetTenantsAsync();
        tenants = tenantsResponse?.Data?.ToList() ?? [];

        var response = await UserService.GetUsersAsync();
        item = response?.Data?.FirstOrDefault(u => u.Id == Id);
        if (item is null) return;

        name = item.Name ?? string.Empty;
        middleName = item.MiddleName ?? string.Empty;
        lastName = item.LastName ?? string.Empty;
        userName = item.UserName ?? string.Empty;
        email = item.Email ?? string.Empty;
        identification = item.Identification ?? string.Empty;
        selectedIdentificationType = identificationTypes.FirstOrDefault(t => t.Id == item.IdentificationTypeId);
        selectedTenant = tenants.FirstOrDefault(t => t.Id == item.TenantId);
    }

    private async Task SaveAsync()
    {
        if (selectedIdentificationType is null || selectedTenant is null) return;

        saving = true;
        var request = new UpdateUserRequest(
            name, middleName, lastName, userName, email, password, identification,
            selectedIdentificationType.Id, selectedTenant.Id);

        var response = await UserService.UpdateUserAsync(Id, request);
        saving = false;

        if (response.IsSuccessStatusCode)
            ToastService.ShowSuccess(L["SavedToast"]);
        else
            ToastService.ShowError(L["SaveFailedToast", (int)response.StatusCode]);
    }

    private async Task DeleteAsync()
    {
        var dialog = await DialogService.ShowConfirmationAsync(L["DeleteUserConfirm", userName], L["Delete"], L["Cancel"], L["ConfirmDeletionTitle"]);
        var result = await dialog.Result;
        if (result.Cancelled) return;

        var response = await UserService.DeleteUserAsync(Id);
        if (response.IsSuccessStatusCode)
        {
            ToastService.ShowSuccess(L["UserDeletedToast"]);
            Nav.NavigateTo("/users");
        }
        else
        {
            ToastService.ShowError(L["UserDeleteFailedToast", (int)response.StatusCode]);
        }
    }
}
