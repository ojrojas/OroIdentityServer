@page "/applications"
@attribute [Authorize]
@inject IAdminApplicationService ApplicationService
@inject IDialogService DialogService
@inject IToastService ToastService
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["ApplicationsTitle"]</PageTitle>

<FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" VerticalAlignment="VerticalAlignment.Center" Style="margin-bottom: 1rem;">
    <FluentLabel Typo="Typography.PageTitle">@L["ApplicationsTitle"]</FluentLabel>
    <FluentButton Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size20.Add())" OnClick="CreateAsync">@L["New"]</FluentButton>
</FluentStack>

@if (items is null)
{
    <FluentProgressRing />
}
else
{
    <FluentDataGrid Items="@items.AsQueryable()" GridTemplateColumns="1.5fr 1.5fr 1fr 1fr">
        <PropertyColumn Title="@L["ClientId"]" Property="@(x => x.ClientId)" Sortable="true" />
        <PropertyColumn Title="@L["ColDisplayName"]" Property="@(x => x.DisplayName)" Sortable="true" />
        <PropertyColumn Title="@L["ColType"]" Property="@(x => x.ClientType)" Sortable="true" />
        <TemplateColumn Title="">
            <FluentButton Appearance="Appearance.Lightweight" IconStart="@(new Icons.Regular.Size16.Edit())" OnClick="@(() => Nav.NavigateTo($"/applications/{context.ClientId}"))" />
            <FluentButton Appearance="Appearance.Lightweight" IconStart="@(new Icons.Regular.Size16.Delete())" OnClick="@(() => DeleteAsync(context))" />
        </TemplateColumn>
    </FluentDataGrid>
}

@code {
    private List<OpenIddictApplicationModel>? items;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        var response = await ApplicationService.GetApplicationsAsync();
        items = response?.ToList() ?? [];
    }

    private async Task CreateAsync()
    {
        var dialog = await DialogService.ShowDialogAsync<CreateApplicationDialog>(new DialogParameters { Title = L["NewApplicationTitle"] });
        var result = await dialog.Result;
        if (!result.Cancelled)
            await LoadAsync();
    }

    private async Task DeleteAsync(OpenIddictApplicationModel item)
    {
        var dialog = await DialogService.ShowConfirmationAsync(L["DeleteApplicationConfirm", item.ClientId ?? string.Empty], L["Delete"], L["Cancel"], L["ConfirmDeletionTitle"]);
        var result = await dialog.Result;
        if (result.Cancelled) return;

        var response = await ApplicationService.DeleteApplicationAsync(item.ClientId!);
        if (response.IsSuccessStatusCode)
        {
            ToastService.ShowSuccess(L["ApplicationDeletedToast"]);
            await LoadAsync();
        }
        else
        {
            ToastService.ShowError(L["ApplicationDeleteFailedToast", (int)response.StatusCode]);
        }
    }
}
