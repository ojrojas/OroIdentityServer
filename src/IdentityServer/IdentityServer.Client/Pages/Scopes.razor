@page "/scopes"
@attribute [Authorize]
@inject IAdminScopeService ScopeService
@inject IDialogService DialogService
@inject IToastService ToastService
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["ScopesTitle"]</PageTitle>

<FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween" VerticalAlignment="VerticalAlignment.Center" Style="margin-bottom: 1rem;">
    <FluentLabel Typo="Typography.PageTitle">@L["ScopesTitle"]</FluentLabel>
    <FluentButton Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size20.Add())" OnClick="CreateAsync">@L["New"]</FluentButton>
</FluentStack>

@if (items is null)
{
    <FluentProgressRing />
}
else
{
    <FluentDataGrid Items="@items.AsQueryable()" GridTemplateColumns="1.5fr 1.5fr 2fr 1fr">
        <PropertyColumn Title="@L["Name"]" Property="@(x => x.Name)" Sortable="true" />
        <PropertyColumn Title="@L["ColDisplayName"]" Property="@(x => x.DisplayName)" Sortable="true" />
        <PropertyColumn Title="@L["ColResources"]" Property="@(x => x.Resources == null ? "" : string.Join(", ", x.Resources))" />
        <TemplateColumn Title="">
            <FluentButton Appearance="Appearance.Lightweight" IconStart="@(new Icons.Regular.Size16.Edit())" Title="@L["Edit"]" OnClick="@(() => Nav.NavigateTo($"/scopes/{context.Name}"))" />
            <FluentButton Appearance="Appearance.Lightweight" IconStart="@(new Icons.Regular.Size16.Delete())" Title="@L["Delete"]" OnClick="@(() => DeleteAsync(context))" />
        </TemplateColumn>
    </FluentDataGrid>
}

@code {
    private List<OpenIddictScopeModel>? items;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        var response = await ScopeService.GetScopesAsync();
        items = response?.ToList() ?? [];
    }

    private void CreateAsync() => Nav.NavigateTo("/scopes/create");

    private async Task DeleteAsync(OpenIddictScopeModel item)
    {
        var dialog = await DialogService.ShowConfirmationAsync(L["DeleteScopeConfirm", item.Name ?? string.Empty], L["Delete"], L["Cancel"], L["ConfirmDeletionTitle"]);
        var result = await dialog.Result;
        if (result.Cancelled) return;

        var response = await ScopeService.DeleteScopeAsync(item.Name!);
        if (response.IsSuccessStatusCode)
        {
            ToastService.ShowSuccess(L["ScopeDeletedToast"]);
            await LoadAsync();
        }
        else
        {
            ToastService.ShowError(L["ScopeDeleteFailedToast", (int)response.StatusCode]);
        }
    }
}
