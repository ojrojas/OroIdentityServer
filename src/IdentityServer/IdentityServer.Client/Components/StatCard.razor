<FluentCard Class="saas-stat-card">
    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="16">
        <div class="saas-stat-icon" style="background: linear-gradient(135deg, var(--saas-accent), color-mix(in srgb, var(--saas-accent) 60%, #000));">
            <FluentIcon Value="@Icon" Color="Color.Fill" />
        </div>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
            <p class="saas-stat-label">@Title</p>
            @if (Value is null)
            {
                <FluentProgressRing Style="width: 22px; height: 22px;" />
            }
            else
            {
                <p class="saas-stat-value">@Value</p>
            }
        </FluentStack>
    </FluentStack>
</FluentCard>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public int? Value { get; set; }

    [Parameter, EditorRequired]
    public Icon Icon { get; set; } = default!;
}