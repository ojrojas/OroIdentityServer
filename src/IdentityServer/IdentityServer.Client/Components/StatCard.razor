<FluentCard Class="stat-card" Style="padding: 20px; height: 100%;">
    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="16">
        <div style="display: flex; align-items: center; justify-content: center; width: 48px; height: 48px; border-radius: 12px; background: linear-gradient(135deg, color-mix(in srgb, var(--diamond, #8EC5D8) 90%, black), color-mix(in srgb, var(--diamond, #8EC5D8) 70%, black));">
            <FluentIcon Value="@Icon" Color="Color.Fill" Style="color: #1a1a1a;" />
        </div>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="2">
            <FluentLabel Typo="Typography.Body" Style="opacity: 0.7; font-size: 0.85rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em;">@Title</FluentLabel>
            @if (Value is null)
            {
                <FluentProgressRing Style="width: 20px; height: 20px;" />
            }
            else
            {
                <FluentLabel Typo="Typography.H3" Style="font-family: 'Playfair Display', Georgia, serif; font-weight: 700; margin: 0;">@Value</FluentLabel>
            }
        </FluentStack>
    </FluentStack>
</FluentCard>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public int? Value { get; set; }

    [Parameter, EditorRequired]
    public Icon Icon { get; set; } = default!;
}
