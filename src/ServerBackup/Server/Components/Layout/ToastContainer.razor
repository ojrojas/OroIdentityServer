@inject ToastService ToastSvc

<div class="toast-container" @ref="_container">
    @foreach (var t in _toasts)
    {
        <div class="toast toast-@t.Type" @onclick="() => Dismiss(t.Id)">
            <span class="toast-icon">
                @(t.Type == "success" ? "&#10003;" : t.Type == "error" ? "&#9888;" : "&#9432;")
            </span>
            <span class="toast-text">@t.Message</span>
        </div>
    }
</div>

@code {
    private List<ToastItem> _toasts = [];
    private ElementReference _container;

    protected override void OnInitialized()
    {
        ToastSvc.OnToast += (type, message) =>
        {
            var id = Guid.NewGuid();
            _toasts.Add(new ToastItem { Id = id, Type = type, Message = message });
            InvokeAsync(StateHasChanged);
            _ = Task.Delay(3000).ContinueWith(_ =>
            {
                _toasts.RemoveAll(t => t.Id == id);
                InvokeAsync(StateHasChanged);
            });
        };
    }

    private void Dismiss(Guid id)
    {
        _toasts.RemoveAll(t => t.Id == id);
        InvokeAsync(StateHasChanged);
    }

    private class ToastItem
    {
        public Guid Id { get; set; }
        public string Type { get; set; } = "";
        public string Message { get; set; } = "";
    }
}
