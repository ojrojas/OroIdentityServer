<AuthorizeView>
    <Authorized>
        <div class="user-badge">
            <div class="user-avatar">@Initials(context.User.Identity?.Name)</div>
            <span class="user-name">@context.User.Identity?.Name</span>
            <form action="/auth/logout" method="post" style="margin:0;display:inline">
                <button class="link" type="submit">Sign Out</button>
            </form>
        </div>
    </Authorized>
    <NotAuthorized>
        <a class="link" href="/login">Sign In</a>
    </NotAuthorized>
</AuthorizeView>

@code {
    private static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split('.', ' ', '_', '@');
        if (parts.Length >= 2 && parts[0].Length > 0 && parts[1].Length > 0)
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        return name.Length > 0 ? name[..1].ToUpper() : "?";
    }
}
