@inherits LayoutComponentBase
@inject NavigationManager Nav

<div class="app-frame" data-theme="@(_dark ? "dark" : "light")">
    <div class="app-shell">
        <aside class="sidebar">
            <svg class="sidebar-logo" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="20" cy="20" r="19" stroke="currentColor" stroke-width="2" fill="none" />
                <path d="M20 1 A19 19 0 0 1 39 20 L20 20 Z" fill="currentColor" />
                <path d="M20 39 A19 19 0 0 1 1 20 L20 20 Z" fill="currentColor" />
            </svg>

            <NavMenu />

            <div class="sidebar-footer">
                <button class="icon-circle" title="Messages">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                         stroke-linejoin="round">
                        <path
                        d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
                    </svg>
                </button>
                <div class="theme-toggle">
                    <button class="@(_dark ? "on" : "")" title="Dark mode" @onclick="() => _dark = true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z" />
                        </svg>
                    </button>
                    <button class="@(_dark ? "" : "on")" title="Light mode" @onclick="() => _dark = false">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="5" />
                            <line x1="12" y1="1" x2="12" y2="3" />
                            <line x1="12" y1="21" x2="12" y2="23" />
                            <line x1="4.2" y1="4.2" x2="5.6" y2="5.6" />
                            <line x1="18.4" y1="18.4" x2="19.8" y2="19.8" />
                            <line x1="1" y1="12" x2="3" y2="12" />
                            <line x1="21" y1="12" x2="23" y2="12" />
                            <line x1="4.2" y1="19.8" x2="5.6" y2="18.4" />
                            <line x1="18.4" y1="5.6" x2="19.8" y2="4.2" />
                        </svg>
                    </button>
                </div>
            </div>
        </aside>

        <div class="main">
            <header class="header">
                <h1>@PageTitle</h1>

                <div class="search">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                         stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8" />
                        <line x1="21" y1="21" x2="16.65" y2="16.65" />
                    </svg>
                    <input type="text" placeholder="Search anything..." />
                </div>

                <button class="btn-create">Create</button>

                <button class="header-icon" title="Notifications">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                         stroke-linejoin="round">
                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                        <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                    </svg>
                    <span class="dot"></span>
                </button>

                <button class="header-icon" title="Messages">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                         stroke-linejoin="round">
                        <path
                        d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
                    </svg>
                </button>

                <a class="header-avatar" href="#" title="Profile">
                    <img src="https://i.pravatar.cc/88?img=12" alt="Profile" />
                </a>
            </header>

            @Body
        </div>
    </div>
</div>

@code {
    private bool _dark;
    private bool _customersOpen;
    private bool _incomeOpen;

    private string PageTitle
    {
        get
        {
            var path = Nav.ToBaseRelativePath(Nav.Uri).Split('?')[0].Trim('/');
            if (string.IsNullOrEmpty(path)) return "Dashboard";
            return char.ToUpperInvariant(path[0]) + path[1..];
        }
    }
}
