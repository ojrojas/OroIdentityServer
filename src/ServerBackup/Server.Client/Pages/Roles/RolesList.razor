@page "/roles"
@rendermode InteractiveAuto
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "AdminOnly")]
@inject IRolesClient Client

<PageTitle>Roles — OroIdentityServer</PageTitle>

<div class="page-header">
    <h1>Roles</h1>
    <p>Manage access roles and permissions.</p>
</div>

<div class="page-toolbar">
    <input class="search-input" @bind-value="_search" placeholder="Search roles..." />
    <div class="toolbar-spacer"></div>
    <div class="inline-bar" style="padding:0">
        <input class="input" @bind-value="_newName" placeholder="New role name" style="width:200px" />
        <button class="btn btn-primary" @onclick="Create">+ Create</button>
    </div>
</div>

<ToastMessage Message="@_toastMsg" Type="@_toastType" OnDismiss="() => _toastMsg = null" />

@if (_items is null)
{
    <div class="text-center py-8"><span class="spinner"></span></div>
}
else if (_filtered.Count() == 0)
{
    <div class="empty-state"><div class="empty-icon">&#9679;</div><div class="empty-title">No roles found</div><div class="empty-desc">@(string.IsNullOrWhiteSpace(_search) ? "Create your first role." : "Try a different search.")</div></div>
}
else
{
    <div class="card">
        <div class="table-wrap">
            <table class="table">
                <thead><tr><th>Name</th><th>Status</th><th></th></tr></thead>
                <tbody>
                    @foreach (var r in _filtered)
                    {
                        <tr>
                            <td class="font-medium">@r.Name</td>
                            <td><span class="status @(r.IsActive ? "status-active" : "status-inactive")">@(r.IsActive ? "Active" : "Inactive")</span></td>
                            <td><div class="action-group"><button class="table-action table-action-delete" @onclick="() => ConfirmDelete(r)" title="Delete">&#128465;</button></div></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (_confirmDelete is not null)
{
    <div class="overlay">
        <div class="dialog" style="min-width:360px;">
            <h2>Delete role</h2>
            <p class="text-secondary" style="margin:0 0 var(--space-4);font-size:13px;">Are you sure you want to delete <strong>@_confirmDelete.Name</strong>?</p>
            <div class="dialog-actions"><button class="btn btn-ghost" @onclick="() => _confirmDelete = null">Cancel</button><button class="btn btn-danger" @onclick="DeleteConfirmed">Delete</button></div>
        </div>
    </div>
}

@code {
    private IReadOnlyList<RoleDto>? _items;
    private RoleDto? _confirmDelete;
    private string _newName = string.Empty;
    private string _search = string.Empty;
    private string? _toastMsg;
    private string _toastType = "success";

    private IEnumerable<RoleDto> _filtered => _items?.Where(r =>
        string.IsNullOrWhiteSpace(_search) || r.Name?.Contains(_search, StringComparison.OrdinalIgnoreCase) == true) ?? [];

    protected override async Task OnInitializedAsync() => await Reload();
    private async Task Reload() => _items = await Client.GetAllAsync();
    private async Task Create()
    {
        if (string.IsNullOrWhiteSpace(_newName)) return;
        await Client.CreateAsync(new() { RoleName = _newName });
        _newName = string.Empty; await Reload();
        Toast("Role created");
    }
    private void ConfirmDelete(RoleDto r) => _confirmDelete = r;
    private async Task DeleteConfirmed() { if (_confirmDelete is null) return; await Client.DeleteAsync(_confirmDelete.Id); _confirmDelete = null; await Reload(); Toast("Role deleted"); }
    private void Toast(string m) { _toastMsg = m; _toastType = "success"; }
}
