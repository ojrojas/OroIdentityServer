@page "/identification-types"
@rendermode InteractiveAuto
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "AdminOnly")]
@inject IIdentificationTypesClient Client

<PageTitle>ID Types — OroIdentityServer</PageTitle>

<div class="page-header">
    <h1>Identification types</h1>
    <p>Manage identification document types for users.</p>
</div>

<div class="page-toolbar">
    <input class="search-input" @bind-value="_search" placeholder="Search ID types..." />
    <div class="toolbar-spacer"></div>
    <div class="inline-bar" style="padding:0">
        <input class="input" @bind-value="_name" placeholder="Name, e.g. Passport" style="width:220px" />
        <button class="btn btn-primary" @onclick="Create">+ Create</button>
    </div>
</div>

<ToastMessage Message="@_toastMsg" Type="@_toastType" OnDismiss="() => _toastMsg = null" />

@if (_items is null) { <div class="text-center py-8"><span class="spinner"></span></div> }
else if (_filtered.Count() == 0) { <div class="empty-state"><div class="empty-icon">&#9679;</div><div class="empty-title">No identification types</div><div class="empty-desc">@(string.IsNullOrWhiteSpace(_search) ? "Create your first type." : "Try a different search.")</div></div> }
else
{
    <div class="card"><div class="table-wrap"><table class="table">
        <thead><tr><th>Name</th><th>Status</th><th>Created</th><th></th></tr></thead>
        <tbody>@foreach (var i in _filtered) { <tr>
            <td class="font-medium">@i.Name</td>
            <td><span class="status @(i.IsActive ? "status-active" : "status-inactive")">@(i.IsActive ? "Active" : "Inactive")</span></td>
            <td class="text-secondary">@i.CreatedAtUtc.ToString("yyyy-MM-dd")</td>
            <td><div class="action-group"><button class="table-action table-action-delete" @onclick="() => ConfirmDelete(i)" title="Delete">&#128465;</button></div></td>
        </tr>}</tbody>
    </table></div></div>
}

@if (_confirmDelete is not null)
{
    <div class="overlay"><div class="dialog" style="min-width:360px;">
        <h2>Delete ID type</h2>
        <p class="text-secondary" style="margin:0 0 var(--space-4);font-size:13px;">Delete <strong>@_confirmDelete.Name</strong>?</p>
        <div class="dialog-actions"><button class="btn btn-ghost" @onclick="() => _confirmDelete = null">Cancel</button><button class="btn btn-danger" @onclick="DeleteConfirmed">Delete</button></div>
    </div></div>
}

@code {
    private IReadOnlyList<IdentificationTypeDto>? _items;
    private IdentificationTypeDto? _confirmDelete;
    private string _name = string.Empty;
    private string _search = string.Empty;
    private string? _toastMsg;
    private string _toastType = "success";

    private IEnumerable<IdentificationTypeDto> _filtered => _items?.Where(i => string.IsNullOrWhiteSpace(_search) || i.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)) ?? [];

    protected override async Task OnInitializedAsync() => await Reload();
    private async Task Reload() => _items = await Client.GetAllAsync();
    private async Task Create() { if (string.IsNullOrWhiteSpace(_name)) return; await Client.CreateAsync(new() { Name = _name }); _name = string.Empty; await Reload(); Toast("ID type created"); }
    private void ConfirmDelete(IdentificationTypeDto i) => _confirmDelete = i;
    private async Task DeleteConfirmed() { if (_confirmDelete is null) return; await Client.DeleteAsync(_confirmDelete.Id); _confirmDelete = null; await Reload(); Toast("ID type deleted"); }
    private void Toast(string m) { _toastMsg = m; _toastType = "success"; }
}
