@page "/nodashboard"
@rendermode InteractiveAuto
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "AdminOnly")]
@inject IUsersClient Users
@inject IRolesClient Roles
@inject IPermissionsClient Permissions
@inject ITenantsClient Tenants
@inject IIdentificationTypesClient IdTypes
@inject IApplicationsClient Apps
@inject IScopesClient Scopes

<PageTitle>Dashboard — OroIdentityServer</PageTitle>

<div class="page-header">
    <h1>Dashboard</h1>
    <p>System overview and resource summary</p>
</div>

@if (_loading)
{
    <div class="text-center py-8"><span class="spinner"></span></div>
}
else
{
    <div class="resource-grid">
        <a class="card resource-card" href="/users">
            <div class="resource-icon">&#9783;</div>
            <div class="resource-value">@_userCount</div>
            <div class="resource-label">Users</div>
        </a>
        <a class="card resource-card" href="/roles">
            <div class="resource-icon">&#9679;</div>
            <div class="resource-value">@_roleCount</div>
            <div class="resource-label">Roles</div>
        </a>
        <a class="card resource-card" href="/permissions">
            <div class="resource-icon">&#9881;</div>
            <div class="resource-value">@_permCount</div>
            <div class="resource-label">Permissions</div>
        </a>
        <a class="card resource-card" href="/tenants">
            <div class="resource-icon">&#9632;</div>
            <div class="resource-value">@_tenantCount</div>
            <div class="resource-label">Tenants</div>
        </a>
        <a class="card resource-card" href="/identification-types">
            <div class="resource-icon">&#9679;</div>
            <div class="resource-value">@_idTypeCount</div>
            <div class="resource-label">ID Types</div>
        </a>
        <a class="card resource-card" href="/applications">
            <div class="resource-icon">&#9679;</div>
            <div class="resource-value">@_appCount</div>
            <div class="resource-label">OAuth Apps</div>
        </a>
        <a class="card resource-card" href="/scopes">
            <div class="resource-icon">&#9679;</div>
            <div class="resource-value">@_scopeCount</div>
            <div class="resource-label">Scopes</div>
        </a>
    </div>

    <div class="db-grid">
        <div class="card">
            <div class="card-header">
                <h3>Recent activity</h3>
            </div>
            <div class="activity-item">
                <span class="activity-dot green"></span>
                <div class="activity-content">
                    <div class="title">@_userCount users registered</div>
                    <div class="meta">Across @_tenantCount active tenants</div>
                </div>
            </div>
            <div class="activity-item">
                <span class="activity-dot blue"></span>
                <div class="activity-content">
                    <div class="title">@_roleCount roles configured</div>
                    <div class="meta">With @_permCount permissions assigned</div>
                </div>
            </div>
            <div class="activity-item">
                <span class="activity-dot amber"></span>
                <div class="activity-content">
                    <div class="title">@_appCount OAuth clients</div>
                    <div class="meta">Across @_idTypeCount identification types</div>
                </div>
            </div>
            <div class="activity-item">
                <span class="activity-dot violet"></span>
                <div class="activity-content">
                    <div class="title">@_scopeCount scopes defined</div>
                    <div class="meta">OpenID Connect and API scopes</div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h3>Quick actions</h3>
            </div>
            <div class="quick-grid">
                <a class="btn btn-primary w-full" href="/users">Manage Users</a>
                <a class="btn btn-ghost w-full" href="/roles">Manage Roles</a>
                <a class="btn btn-ghost w-full" href="/tenants">Manage Tenants</a>
                <a class="btn btn-ghost w-full" href="/applications">OAuth Apps</a>
                <a class="btn btn-ghost w-full" href="/permissions">Permissions</a>
                <a class="btn btn-ghost w-full" href="/scopes">Manage Scopes</a>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private int _userCount, _roleCount, _permCount, _tenantCount, _idTypeCount, _appCount, _scopeCount;

    protected override async Task OnInitializedAsync()
    {
        var tasks = new Task[]
        {
            TryLoad(async () => _userCount = (await Users.GetAllAsync()).Count),
            TryLoad(async () => _roleCount = (await Roles.GetAllAsync()).Count),
            TryLoad(async () => _permCount = (await Permissions.GetAllAsync()).Count),
            TryLoad(async () => _tenantCount = (await Tenants.GetAllAsync()).Count),
            TryLoad(async () => _appCount = (await Apps.GetAllAsync()).Count),
            TryLoad(async () => _scopeCount = (await Scopes.GetAllAsync()).Count),
            TryLoad(async () => _idTypeCount = (await IdTypes.GetAllAsync()).Count),
        };
        await Task.WhenAll(tasks);
        _loading = false;
    }

    private static async Task TryLoad(Func<Task> loader)
    {
        try { await loader(); } catch { /* skip on error */ }
    }
}
