@page "/"
@layout Layout.AdminLayout

@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "AdminOnly")]
@inject IUsersClient Users
@inject IRolesClient Roles
@inject IPermissionsClient Permissions
@inject ITenantsClient Tenants
@inject IIdentificationTypesClient IdTypes
@inject IApplicationsClient Apps
@inject IScopesClient Scopes

<PageTitle>Dashboard — OroIdentityServer</PageTitle>

<div class="page-header">
    <h1>Dashboard</h1>
    <p>System overview and resource summary</p>
</div>


<PageTitle>Dashboard</PageTitle>

<div class="content">

    @* ===== Left column ===== *@
    <div class="col">

        @* Overview *@
        <section class="card">
            <div class="card-head">
                <span class="card-title">Overview</span>
                <button class="select-pill">
                    @_overviewPeriod
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
                </button>
            </div>

            <div class="stats">
                <div class="stat @(_selectedStat == 0 ? "selected" : "")" @onclick="() => _selectedStat = 0">
                    <div class="stat-label">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                        Customers
                    </div>
                    <div class="stat-value">
                        <span class="num">1,293</span>
                        <span class="badge down">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><path d="M19 12l-7 7-7-7"/></svg>
                            36.8%
                        </span>
                    </div>
                    <div class="stat-sub">vs last month</div>
                </div>

                <div class="stat @(_selectedStat == 1 ? "selected" : "")" @onclick="() => _selectedStat = 1">
                    <div class="stat-label">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
                        Balance
                    </div>
                    <div class="stat-value">
                        <span class="num">256k</span>
                        <span class="badge up">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="19" x2="12" y2="5"/><path d="M5 12l7-7 7 7"/></svg>
                            36.8%
                        </span>
                    </div>
                    <div class="stat-sub">vs last month</div>
                </div>
            </div>

            <div class="new-customers">
                <h3>857 new customers today!</h3>
                <p>Send a welcome message to all new customers.</p>

                <div class="avatar-row">
                    @foreach (var c in _newCustomers)
                    {
                        <div class="avatar-item">
                            <span class="pic"><img src="https://i.pravatar.cc/112?img=@c.Img" alt="@c.Name" /></span>
                            @c.Name
                        </div>
                    }
                    <a class="avatar-item" href="customers">
                        <span class="pic view-all">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><path d="M12 5l7 7-7 7"/></svg>
                        </span>
                        View all
                    </a>
                </div>
            </div>
        </section>

        @* Product view *@
        <section class="card">
            <div class="card-head">
                <span class="card-title">Product view</span>
                <button class="select-pill">
                    @_chartPeriod
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
                </button>
            </div>

            <div class="chart-wrap">
                <span class="chart-watermark">$10.2m</span>
                @for (var i = 0; i < _bars.Length; i++)
                {
                    var index = i;
                    var bar = _bars[index];
                    <div class="bar @(_activeBar == index ? "active" : "")"
                         style="height:@(bar.Percent)%"
                         @onmouseover="() => _activeBar = index">
                        <span class="tip">@bar.Label</span>
                    </div>
                }
            </div>
        </section>
    </div>

    @* ===== Right column ===== *@
    <div class="col">

        @* Popular products *@
        <section class="card">
            <div class="card-head" style="margin-bottom:8px">
                <span class="card-title">Popular products</span>
            </div>

            @foreach (var p in _products)
            {
                <div class="product-row">
                    <span class="product-thumb">@p.Art</span>
                    <div class="product-info">
                        <div class="name">@p.Name</div>
                    </div>
                    <div class="product-meta">
                        <span class="price">@p.Price</span>
                        <span class="status @(p.Active ? "active" : "offline")">@(p.Active ? "Active" : "Offline")</span>
                    </div>
                </div>
            }

            <a class="btn-outline" href="products">All products</a>
        </section>

        @* Comments *@
        <section class="card">
            <div class="card-head" style="margin-bottom:8px">
                <span class="card-title">Comments</span>
            </div>

            @foreach (var c in _comments)
            {
                <div class="comment">
                    <span class="pic"><img src="https://i.pravatar.cc/80?img=@c.Img" alt="@c.Author" /></span>
                    <div>
                        <div class="who">@c.Author <span class="on">on</span> @c.Product</div>
                        <div class="time">@c.Time</div>
                        <div class="text">@c.Text</div>
                    </div>
                </div>
            }
        </section>
    </div>
</div>

@code {
    private int _selectedStat;
    private int _activeBar = 3;
    private readonly string _overviewPeriod = "Last month";
    private readonly string _chartPeriod = "Last 7 days";

    private record Bar(int Percent, string Label);

    private readonly Bar[] _bars =
    {
        new(32, "1.1m"),
        new(52, "1.6m"),
        new(44, "1.4m"),
        new(90, "2.2m"),
        new(60, "1.8m"),
        new(28, "0.9m"),
        new(40, "1.3m"),
        new(68, "1.9m"),
    };

    private record Customer(string Name, int Img);

    private readonly Customer[] _newCustomers =
    {
        new("Gladyce", 47),
        new("Elbert", 11),
        new("Dash", 13),
        new("Joyce", 59),
        new("Marina", 32),
    };

    private record Comment(string Author, int Img, string Product, string Time, string Text);

    private readonly Comment[] _comments =
    {
        new("Joyce", 59, "Bento Pro 2.0", "09:00 AM",
            "Great work! When HTML version will be available? ⚡"),
        new("Gladyce", 47, "Food Delivery App", "08:32 AM",
            "Amazing quality! Can I use these illustrations in a commercial project?"),
    };

    private record Product(string Name, string Price, bool Active, RenderFragment Art);

    private Product[] _products = default!;

    protected override void OnInitialized()
    {
        _products = new Product[]
        {
            new("Crypter - NFT UI Kit", "$3,250.00", true, ThumbCrypter),
            new("Bento Pro 2.0 Illustrations", "$7,890.00", true, ThumbBento2),
            new("Fleet - travel shopping kit", "$1,500.00", false, ThumbFleet),
            new("SimpleSocial UI Design Kit", "$9,999.99", true, ThumbSocial),
            new("Bento Pro vol. 2", "$4,750.00", true, ThumbBentoV2),
        };
    }

    private static readonly RenderFragment ThumbCrypter = @<svg viewBox="0 0 56 56" xmlns="http://www.w3.org/2000/svg"><rect width="56" height="56" fill="#dbe3c5"/><path d="M18 38c-4-6 0-16 8-18s16 2 14 10-6 12-12 12-8-1-10-4z" fill="#a3b83c"/><circle cx="24" cy="26" r="5" fill="#7d9420"/><path d="M32 20l6 4-2 8-8-2z" fill="#c3d36a"/></svg>;

    private static readonly RenderFragment ThumbBento2 = @<svg viewBox="0 0 56 56" xmlns="http://www.w3.org/2000/svg"><rect width="56" height="56" fill="#2d2b55"/><rect x="6" y="6" width="20" height="20" rx="4" fill="#5a54d4"/><rect x="30" y="6" width="20" height="20" rx="4" fill="#e34f4f"/><rect x="6" y="30" width="20" height="20" rx="4" fill="#f4c542"/><rect x="30" y="30" width="20" height="20" rx="4" fill="#4fb8e3"/><circle cx="16" cy="16" r="6" fill="#fcfcfc" opacity=".85"/><path d="M34 44l6-10 6 10z" fill="#fcfcfc" opacity=".85"/></svg>;

    private static readonly RenderFragment ThumbFleet = @<svg viewBox="0 0 56 56" xmlns="http://www.w3.org/2000/svg"><rect width="56" height="56" fill="#b6b0a6"/><rect x="10" y="30" width="36" height="16" fill="#8f887c"/><path d="M20 18l12-4 4 12-12 4z" fill="#e2622b"/><path d="M32 14l6 2-2 10-4-4z" fill="#f28b4f"/></svg>;

    private static readonly RenderFragment ThumbSocial = @<svg viewBox="0 0 56 56" xmlns="http://www.w3.org/2000/svg"><rect width="56" height="56" fill="#f4e9c8"/><circle cx="28" cy="26" r="10" fill="#f4a52e"/><path d="M0 36c10-8 20-8 28-2s18 6 28-2v24H0z" fill="#4a8f52"/><path d="M0 44c12-6 24-4 32 0s16 4 24 0v12H0z" fill="#2f6b3a"/></svg>;

    private static readonly RenderFragment ThumbBentoV2 = @<svg viewBox="0 0 56 56" xmlns="http://www.w3.org/2000/svg"><rect width="56" height="56" fill="#3b2b63"/><circle cx="38" cy="16" r="7" fill="#f4d03f"/><path d="M0 56L20 26l14 18 8-10 14 22z" fill="#7a4fb8"/><path d="M0 56l14-20 10 14 6-6 10 12z" fill="#b85fa0"/></svg>;
}
