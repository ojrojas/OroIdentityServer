@page "/scopes"
@rendermode InteractiveAuto
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "AdminOnly")]
@inject IScopesClient Client

<PageTitle>Scopes — OroIdentityServer</PageTitle>

<div class="page-header">
    <h1>OAuth scopes</h1>
    <p>Manage OpenID Connect scopes and claims.</p>
</div>

<div class="page-toolbar">
    <input class="search-input" @bind-value="_search" placeholder="Search scopes..." />
    <div class="toolbar-spacer"></div>
    <div class="inline-bar" style="padding:0">
        <input class="input" @bind-value="_editing.Name" placeholder="Scope name" style="width:180px" />
        <input class="input" @bind-value="_resourcesText" placeholder="Resources (comma-sep)" style="width:240px" />
        <button class="btn btn-primary" @onclick="Save">+ Create</button>
    </div>
</div>

<ToastMessage Message="@_toastMsg" Type="@_toastType" OnDismiss="() => _toastMsg = null" />

@if (_items is null) { <div class="text-center py-8"><span class="spinner"></span></div> }
else if (_filtered.Count() == 0) { <div class="empty-state"><div class="empty-icon">&#9679;</div><div class="empty-title">No scopes found</div><div class="empty-desc">@(string.IsNullOrWhiteSpace(_search) ? "Create your first scope." : "Try a different search.")</div></div> }
else
{
    <div class="card"><div class="table-wrap"><table class="table">
        <thead><tr><th>Name</th><th>Resources</th><th></th></tr></thead>
        <tbody>@foreach (var s in _filtered) { <tr>
            <td class="font-medium">@s.Name</td>
            <td class="text-secondary">@JoinResources(s.Resources)</td>
            <td><div class="action-group"><button class="table-action table-action-delete" @onclick="() => ConfirmDelete(s)" title="Delete">&#128465;</button></div></td>
        </tr>}</tbody>
    </table></div></div>
}

@if (_confirmDelete is not null)
{
    <div class="overlay"><div class="dialog" style="min-width:360px;">
        <h2>Delete scope</h2>
        <p class="text-secondary" style="margin:0 0 var(--space-4);font-size:13px;">Delete scope <strong>@_confirmDelete.Name</strong>?</p>
        <div class="dialog-actions"><button class="btn btn-ghost" @onclick="() => _confirmDelete = null">Cancel</button><button class="btn btn-danger" @onclick="DeleteConfirmed">Delete</button></div>
    </div></div>
}

@code {
    private IReadOnlyList<ScopeDto>? _items;
    private ScopeDto _editing = new();
    private ScopeDto? _confirmDelete;
    private string _resourcesText = string.Empty;
    private string _search = string.Empty;
    private string? _toastMsg;
    private string _toastType = "success";

    private IEnumerable<ScopeDto> _filtered => _items?.Where(s => string.IsNullOrWhiteSpace(_search) || s.Name.Contains(_search, StringComparison.OrdinalIgnoreCase) || s.Resources.Any(r => r.Contains(_search, StringComparison.OrdinalIgnoreCase))) ?? [];

    protected override async Task OnInitializedAsync() => await Reload();
    private async Task Reload() => _items = await Client.GetAllAsync();

    private async Task Save() {
        if (string.IsNullOrWhiteSpace(_editing.Name)) return;
        _editing.Resources = _resourcesText.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
        await Client.CreateAsync(_editing); _editing = new(); _resourcesText = string.Empty; await Reload(); Toast("Scope created");
    }

    private void ConfirmDelete(ScopeDto s) => _confirmDelete = s;
    private async Task DeleteConfirmed() { if (_confirmDelete is null) return; await Client.DeleteAsync(_confirmDelete.Name); _confirmDelete = null; await Reload(); Toast("Scope deleted"); }
    private static string JoinResources(List<string> r) => string.Join(", ", r);
    private void Toast(string m) { _toastMsg = m; _toastType = "success"; }
}
