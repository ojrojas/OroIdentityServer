@page "/products"
@page "/customers"
@page "/shop"
@page "/income"
@page "/promote"
@layout Layout.AdminLayout
@inject NavigationManager Nav

<PageTitle>@Title</PageTitle>

<div class="content" style="grid-template-columns:1fr">
    <section class="card" style="min-height:400px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px">
        <span class="card-title">@Title</span>
        <span style="color:var(--text-tertiary)">This section is under construction.</span>
    </section>
</div>

@code {
    private string Title
    {
        get
        {
            var path = Nav.ToBaseRelativePath(Nav.Uri).Split('?')[0].Trim('/');
            return string.IsNullOrEmpty(path) ? "Dashboard" : char.ToUpperInvariant(path[0]) + path[1..];
        }
    }
}
