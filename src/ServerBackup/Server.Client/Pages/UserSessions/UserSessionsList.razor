@page "/user-sessions"
@rendermode InteractiveAuto
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Policy = "AdminOnly")]
@inject IUserSessionsClient Client

<PageTitle>Sessions — OroIdentityServer</PageTitle>

<div class="page-header">
    <h1>User sessions</h1>
    <p>View and manage active user sessions.</p>
</div>

<div class="page-toolbar">
    <input class="search-input" @bind-value="_userIdInput" placeholder="Enter user ID (Guid)..." style="min-width:280px" />
    <button class="btn btn-primary" @onclick="Load">Load sessions</button>
</div>

<ToastMessage Message="@_toastMsg" Type="@_toastType" OnDismiss="() => _toastMsg = null" />

@if (_loading) { <div class="text-center py-8"><span class="spinner"></span></div> }
else if (_items is null) { <div class="empty-state"><div class="empty-icon">&#9675;</div><div class="empty-title">Search for user sessions</div><div class="empty-desc">Enter a user ID above and click Load sessions.</div></div> }
else if (_items.Count == 0) { <div class="empty-state"><div class="empty-icon">&#9675;</div><div class="empty-title">No sessions found</div><div class="empty-desc">This user has no active or past sessions.</div></div> }
else
{
    <div class="card"><div class="table-wrap"><table class="table">
        <thead><tr><th>Device</th><th>IP address</th><th>Expires</th><th>Status</th><th></th></tr></thead>
        <tbody>@foreach (var s in _items) { <tr>
            <td class="font-medium">@s.Device</td>
            <td class="text-secondary">@s.IpAddress</td>
            <td class="text-secondary">@s.ExpiresAt.ToString("g")</td>
            <td><span class="status @(s.IsActive ? "status-active" : "status-inactive")">@(s.IsActive ? "Active" : "Expired")</span></td>
            <td><div class="action-group">
                @if (s.IsActive) { <button class="table-action table-action-danger" @onclick="() => Deactivate(s.Id)">Deactivate</button> }
            </div></td>
        </tr>}</tbody>
    </table></div></div>
}

@code {
    private string _userIdInput = string.Empty;
    private IReadOnlyList<UserSessionDto>? _items;
    private bool _loading;
    private string? _toastMsg;
    private string _toastType = "success";

    private async Task Load()
    {
        if (!Guid.TryParse(_userIdInput, out var id)) return;
        _loading = true;
        try { _items = await Client.GetByUserAsync(id); } finally { _loading = false; }
    }

    private async Task Deactivate(Guid id) { await Client.DeactivateAsync(id); await Load(); Toast("Session deactivated"); }
    private void Toast(string m) { _toastMsg = m; _toastType = "success"; }
}
